# OpenRouter API (ตัวหลัก)
# รับ Key ที่: https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_key_here
OPENROUTER_MODEL=openai/gpt-4o-mini

# Groq API (เร็วและแรง - ฟรีโควต้าเยอะ)
# รับ Key ที่: https://console.groq.com/keys
GROQ_API_KEY=your_groq_key_here

# Google Gemini API (ฉลาดและสเถียร - ฟรี 15 RPM)
# รับ Key ที่: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_key_here
